# NOTE:
# This aggregated file is kept for backward compatibility.
# Context-specific templates now live in:
# - infrastructure/env/automation/.env.example
# - infrastructure/env/supabase/.env.example

# -----------------------
# n8n
# -----------------------
N8N_VERSION=1.101.0
N8N_BASIC_AUTH_USER=change-me
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_SECURE_COOKIE=false
N8N_PAYLOAD_SIZE_MAX=256
N8N_HOST=your-domain.example.com
N8N_PROTOCOL=https
N8N_EDITOR_BASE_URL=https://your-domain.example.com
WEBHOOK_URL=https://your-domain.example.com
N8N_PROXY_HOPS=1
N8N_DEFAULT_BINARY_DATA_MODE=filesystem
PARAKEET_MODEL=nvidia/parakeet-tdt-0.6b-v3
PARAKEET_DEVICE=cpu
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=
OPENAI_WHISPER_MODEL=whisper-1


# -----------------------
# URLs
# -----------------------
SITE_URL=http://n8n.local:3000
API_EXTERNAL_URL=http://n8n.local:8000
SUPABASE_PUBLIC_URL=http://n8n.local:8000
ADDITIONAL_REDIRECT_URLS=http://n8n.local:3000,http://n8n.local:5678


# -----------------------
# Postgres
# -----------------------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_PASSWORD=postgres
PGRST_DB_SCHEMAS=public,storage,graphql_public


# -----------------------
# Studio
# -----------------------
STUDIO_DEFAULT_ORGANIZATION=n8n-local
STUDIO_DEFAULT_PROJECT=supabase


# -----------------------
# JWT / Keys
# -----------------------
JWT_SECRET=change-me
ANON_KEY=change-me
SERVICE_ROLE_KEY=change-me
PG_META_CRYPTO_KEY=change-me
SECRET_KEY_BASE=change-me
VAULT_ENC_KEY=change-me
LOGFLARE_PUBLIC_ACCESS_TOKEN=change-me
LOGFLARE_PRIVATE_ACCESS_TOKEN=change-me


# -----------------------
# Auth behaviour
# -----------------------
DISABLE_SIGNUP=false
JWT_EXPIRY=3600
ENABLE_EMAIL_SIGNUP=false
ENABLE_ANONYMOUS_USERS=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=true


# -----------------------
# SMTP
# -----------------------
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Supabase
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify


# -----------------------
# Storage
# -----------------------
STORAGE_TENANT_ID=stub
REGION=local
GLOBAL_S3_BUCKET=stub
S3_PROTOCOL_ACCESS_KEY_ID=stub
S3_PROTOCOL_ACCESS_KEY_SECRET=stub
IMGPROXY_ENABLE_WEBP_DETECTION=true


# -----------------------
# Functions
# -----------------------
FUNCTIONS_VERIFY_JWT=false


# -----------------------
# Kong dashboard
# -----------------------
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin
