FROM python:3.11-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends ffmpeg && \
    rm -rf /var/lib/apt/lists/*

COPY infrastructure/docker/whisper/requirements.lock /tmp/requirements.lock

RUN pip install --no-cache-dir -U pip setuptools wheel && \
    pip install --no-cache-dir -r /tmp/requirements.lock

WORKDIR /app

COPY services/whisper_chunk_api /app/whisper_chunk_api

CMD ["uvicorn", "whisper_chunk_api.main:app", "--host", "0.0.0.0", "--port", "8000"]
