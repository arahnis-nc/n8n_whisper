FROM python:3.11-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends ffmpeg && \
    rm -rf /var/lib/apt/lists/*

COPY infrastructure/docker/audio-ingest/requirements.lock /tmp/requirements.lock

RUN pip install --no-cache-dir -U pip setuptools wheel && \
    pip install --no-cache-dir -r /tmp/requirements.lock

WORKDIR /app

COPY services/audio_ingest_api /app/audio_ingest_api

CMD ["uvicorn", "audio_ingest_api.main:app", "--host", "0.0.0.0", "--port", "8000"]

