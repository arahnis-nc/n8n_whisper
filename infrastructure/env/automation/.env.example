# ASR services
PARAKEET_MODEL=nvidia/parakeet-tdt-0.6b-v3
PARAKEET_DEVICE=cpu

OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=
OPENAI_WHISPER_MODEL=whisper-1

# Whisper worker
WHISPER_TASKS_DB_PATH=/data/whisper/whisper.db
WHISPER_OUTBOX_POLL_SECONDS=3
WHISPER_OUTBOX_BATCH_SIZE=10
WHISPER_WORKER_COUNT=1
WHISPER_WORKER_LOG_LEVEL=INFO
WHISPER_ALLOWED_INPUT_DIRS=/data/records,/data/audio/processed
WHISPER_TEXT_POSTPROCESS_ENABLED=true
WHISPER_TEXT_POSTPROCESS_MODEL=gpt-4o-mini
WHISPER_TEXT_POSTPROCESS_TEMPERATURE=0.2

# Audio ingest worker
AUDIO_OUTBOX_POLL_SECONDS=3
AUDIO_OUTBOX_BATCH_SIZE=10
WHISPER_TASK_BACKEND=cloud
WHISPER_TASK_MODEL=tiny
WHISPER_TASK_CLOUD_MODEL=whisper-1
WHISPER_TASK_MODE=transcribe
WHISPER_TASK_CHUNK_SECONDS=300
WHISPER_TASK_LANGUAGE=ru
WHISPER_TASK_PROMPT=
WHISPER_TASK_TEMPERATURE=0.0

# SMTP notification worker
AUDIO_NOTIFY_POLL_SECONDS=5
AUDIO_NOTIFY_BATCH_SIZE=10
AUDIO_NOTIFY_WORKER_LOG_LEVEL=INFO
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
SMTP_USE_STARTTLS=true

